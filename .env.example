# Local OpenAI-compatible fallback
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_CHAT_MODEL=local-model

# Shared AI API key
API_KEY=

# Chat model
CHAT_BASE_URL=https://api.vsellm.ru/v1
CHAT_MODEL=openai/gpt-oss-120b
CHAT_API_KEY=

# Embedding model
EMBEDDING_BASE_URL=https://api.vsellm.ru/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# Local PostgreSQL database with pgvector catalog search
DATABASE_URL=postgresql://argus:argus@127.0.0.1:5432/argus
AUTH_SESSION_TTL_SECONDS=604800

# Local container proxy bypass
NO_PROXY=localhost,127.0.0.1,::1,0.0.0.0,host.docker.internal
no_proxy=localhost,127.0.0.1,::1,0.0.0.0,host.docker.internal

# Local dev/test admin seed
DEV_ADMIN_EMAIL=developer@example.com
DEV_ADMIN_PASSWORD=
DEV_ADMIN_ROLE=admin
