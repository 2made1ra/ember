# Local OpenAI-compatible fallback
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_CHAT_MODEL=local-model

# Shared AI API key
API_KEY=

# Chat model
CHAT_BASE_URL=https://api.vsellm.ru/v1
CHAT_MODEL=openai/gpt-oss-120b
CHAT_API_KEY=

# Embedding model
EMBEDDING_BASE_URL=https://api.vsellm.ru/v1
EMBEDDING_MODEL=openai/text-embedding-3-small

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=argus_price_items

# Local container proxy bypass
NO_PROXY=localhost,127.0.0.1,::1,0.0.0.0,host.docker.internal
no_proxy=localhost,127.0.0.1,::1,0.0.0.0,host.docker.internal

# Local Supabase Auth, backend token validation
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=

# Local Supabase Auth, dev/test admin seed only
SUPABASE_SERVICE_ROLE_KEY=
DEV_ADMIN_EMAIL=developer@example.com
DEV_ADMIN_PASSWORD=
DEV_ADMIN_ROLE=admin

# Local Supabase SQL, reserved for future database features
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local Supabase Auth, frontend browser client
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=
